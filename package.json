{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "react-doctor": "react-doctor --score",
    "format": "biome format --write",
    "cf:build": "pnpm exec opennextjs-cloudflare build",
    "cf:preview": "pnpm exec opennextjs-cloudflare preview",
    "cf:deploy": "pnpm run cf:build && pnpm exec opennextjs-cloudflare deploy",
    "preview": "pnpm run cf:build && pnpm run cf:preview",
    "deploy": "pnpm run cf:deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
