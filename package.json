    "autoprefixer": "^10.4.16",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "react-doctor": "^0.2.9",
    "tailwindcss": "^3.4.13",
